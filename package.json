{
  "name": "agent-black-box",
  "version": "0.1.0",
  "description": "Local-first CLI that records and explains observable repository changes during AI coding sessions.",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IACBI/agent-black-box.git"
  },
  "bugs": {
    "url": "https://github.com/IACBI/agent-black-box/issues"
  },
  "homepage": "https://github.com/IACBI/agent-black-box#readme",
  "bin": {
    "abb": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "ai",
    "cli",
    "audit",
    "git",
    "developer-tools"
  ],
  "author": "𝓐.𝓒.𝓑",
  "license": "MIT",
  "dependencies": {
    "chokidar": "^5.0.0",
    "commander": "^14.0.2",
    "simple-git": "^3.28.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.17",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
